# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=[your-anon-key]

# AI API (OpenRouter)
OPENROUTER_API_KEY=sk-or-[your-key]
# Recommended free model: meta-llama/llama-3.3-70b-instruct:free
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# AI API Alternative (Hugging Face - Free Tier)
HUGGINGFACE_API_KEY=hf_[your-key]
# Recommended models:
# - meta-llama/Meta-Llama-3-8B-Instruct (default, fast)
# - mistralai/Mixtral-8x7B-Instruct-v0.1 (higher quality, slower)
# - HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# OpenAI API (Optional - for knowledge base embeddings)
# Only needed if you want semantic search in knowledge base
# If not set, knowledge base will work with keyword search only
OPENAI_API_KEY=sk-[your-openai-key]

# WhatsApp (Meta Cloud API - Free Tier)
META_WHATSAPP_TOKEN=[your-access-token]
META_WHATSAPP_PHONE_ID=[your-phone-id]
META_WHATSAPP_BUSINESS_ID=[your-business-id]
# Required for webhook signature verification (from Meta App Dashboard → Settings → Basic)
WHATSAPP_APP_SECRET=[your-app-secret]

# Email (Gmail API)
GMAIL_OAUTH_TOKEN=[your-gmail-oauth-token]
GMAIL_REFRESH_TOKEN=[your-gmail-refresh-token]
GMAIL_CLIENT_ID=[your-oauth-client-id]
GMAIL_CLIENT_SECRET=[your-oauth-client-secret]
GMAIL_SERVICE_ACCOUNT_EMAIL=[your-service-account-email]
SUPPORT_EMAIL=support@example.com

# Redpanda (Kafka-compatible)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=[generate-random-string-with-at-least-32-characters]

# Internal API Authentication
# Generate secure API keys for internal endpoints (customers, conversations, metrics)
# Use: python -c "import secrets; print(secrets.token_hex(32))"
# Multiple keys can be comma-separated for key rotation
INTERNAL_API_KEYS=[your-api-key-1],[your-api-key-2]

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Frontend Configuration (for Next.js API routes)
BACKEND_URL=http://localhost:8000
