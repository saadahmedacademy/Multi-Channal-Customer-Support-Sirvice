"""Production environment configuration."""

# Production Environment Variables Template
# Copy this to .env.production and fill in actual values

# ================== DATABASE ==================
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/[DATABASE]

# ================== AI API ==================
OPENROUTER_API_KEY=sk-or-[YOUR-KEY]
AI_MODEL=meta-llama/llama-3.3-70b-instruct

# OR use Gemini
# GEMINI_API_KEY=[YOUR-GEMINI-KEY]

# ================== WHATSAPP ==================
META_WHATSAPP_TOKEN=[YOUR-ACCESS-TOKEN]
META_WHATSAPP_PHONE_ID=[YOUR-PHONE-ID]
META_WHATSAPP_BUSINESS_ID=[YOUR-BUSINESS-ID]
WHATSAPP_APP_SECRET=[YOUR-APP-SECRET]
WHATSAPP_VERIFY_TOKEN=[YOUR-VERIFY-TOKEN]

# ================== EMAIL ==================
GMAIL_CLIENT_ID=[YOUR-CLIENT-ID]
GMAIL_CLIENT_SECRET=[YOUR-CLIENT-SECRET]
GMAIL_REFRESH_TOKEN=[YOUR-REFRESH-TOKEN]
SUPPORT_EMAIL=support@yourdomain.com

# ================== REDPANDA/KAFKA ==================
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092

# ================== APPLICATION ==================
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=[GENERATE-WITH: python -c "import secrets; print(secrets.token_urlsafe(32))"]

# ================== CORS ==================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ================== RATE LIMITING ==================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ================== SECURITY ==================
INTERNAL_API_KEYS=[GENERATE-WITH: python -c "import secrets; print(secrets.token_hex(32))"]

# ================== MONITORING ==================
SENTRY_DSN=[YOUR-SENTRY-DSN]
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ================== FRONTEND ==================
BACKEND_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
